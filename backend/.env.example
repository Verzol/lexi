# --- Database ---
# Supabase (what the app actually runs on). Project Settings → Database →
# Connection string → URI, and pick the SESSION POOLER (port 5432):
#   - session pooler (5432)     -> use this; works with Alembic, supports IPv4
#   - transaction pooler (6543) -> cannot run Alembic migrations
#   - direct connection         -> IPv6 only
# Rewrite the scheme to postgresql+psycopg:// (the bare postgresql:// makes
# SQLAlchemy look for psycopg2, which is not installed). URL-encode any special
# characters in the password (@ -> %40, etc).
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Local Postgres via `docker compose up -d`. Only the test suite needs this —
# tests/conftest.py pins itself to it and ignores this file.
# DATABASE_URL=postgresql+psycopg://lexi:lexi@localhost:5433/lexi

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me
# Must be true in production (HTTPS).
COOKIE_SECURE=false

CORS_ORIGINS=["http://localhost:3000"]

# --- Seed accounts (app/seed.py) ---
# Note: email-validator rejects reserved TLDs like .local / .test.
SEED_ADMIN_EMAIL=teacher@lexi.app
SEED_ADMIN_PASSWORD=changeme
